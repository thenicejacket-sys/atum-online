# ATUM Online — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs

# Port du serveur (Railway le définit automatiquement)
PORT=3001

# Environnement
NODE_ENV=production

# URL du frontend (pour CORS - laisser vide pour autoriser tout en dev)
FRONTEND_URL=https://atum.vercel.app

# Répertoire de données (optionnel — défaut : ./data)
# DATA_DIR=/data
